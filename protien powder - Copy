<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Protein Powder Ad</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #111;
            color: white;
        }

        header {
            display: flex;
            justify-content: space-between;
            padding: 20px 50px;
            background: #000;
        }

        header h1 {
            color: #f5c518;
        }

        nav a {
            margin: 0 15px;
            color: white;
            text-decoration: none;
        }

        .hero {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 50px;
        }

        .hero-text {
            max-width: 50%;
        }

        .hero-text h2 {
            font-size: 50px;
        }

        .highlight {
            color: #f5c518;
        }

        .hero-text p {
            font-size: 18px;
            margin: 20px 0;
        }

        .btn {
            background: #f5c518;
            color: black;
            padding: 12px 25px;
            border: none;
            cursor: pointer;
            font-weight: bold;
        }

        .hero img {
            width: 350px;
        }

        .features {
            display: flex;
            justify-content: space-around;
            background: #222;
            padding: 40px;
            text-align: center;
        }

        .features div {
            max-width: 200px;
        }

        .features h3 {
            color: #f5c518;
        }

        .flavors {
            text-align: center;
            padding: 50px;
        }

        .flavor-list {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
        }

        .flavor {
            background: #222;
            padding: 15px 25px;
            border-radius: 10px;
        }

        footer {
            text-align: center;
            padding: 20px;
            background: #000;
            margin-top: 30px;
        }
    </style>
</head>
<body>

<header>
    <h1>FITFUEL</h1>
    <nav>
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Benefits</a>
        <a href="#">Flavors</a>
    </nav>
</header>

<section class="hero">
    <div class="hero-text">
        <h2>BUILD <span class="highlight">STRENGTH</span><br>BUILD YOU</h2>
        <p>Premium protein powder for muscle growth, recovery & daily performance.</p>
        <button class="btn">BUY NOW</button>
    </div>

    <img src="https://via.placeholder.com/350x400" alt="Protein Powder">
</section>

<section class="features">
    <div>
        <h3>24g Protein</h3>
        <p>High-quality protein per serving</p>
    </div>
    <div>
        <h3>Fast Recovery</h3>
        <p>Reduces muscle soreness</p>
    </div>
    <div>
        <h3>Immune Support</h3>
        <p>Boosts overall health</p>
    </div>
    <div>
        <h3>Easy Mix</h3>
        <p>Smooth & delicious taste</p>
    </div>
</section>

<section class="flavors">
    <h2>Available Flavors</h2>
    <div class="flavor-list">
        <div class="flavor">Chocolate</div>
        <div class="flavor">Vanilla</div>
        <div class="flavor">Strawberry</div>
        <div class="flavor">Cookies & Cream</div>
    </div>
</section>

<footer>
    <p>© 2026 FITFUEL Protein. All rights reserved.</p>
</footer>

</body>
</html>
